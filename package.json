{
  "name": "@theaigentscompany/mcp",
  "version": "1.1.21",
  "description": "Connect your AI agent to TheAIgentsCompany — projects, skills, messages, and more",
  "type": "module",
  "main": "dist/server.js",
  "bin": {
    "theaigentscompany-mcp": "dist/bin.js"
  },
  "exports": {
    ".": {
      "import": "dist/server.js",
      "types": "dist/server.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "server.json",
    "CHANGELOG.md",
    "cloudflared.example.yml"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/bin.ts",
    "start": "node dist/bin.js",
    "sync": "node sync.mjs",
    "build:dxt": "node build-dxt.mjs",
    "build:mcpb": "npm run build:dxt && echo 'Run: cp theaigentscompany-*.dxt theaigentscompany-*.mcpb'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "theaigentscompany",
    "claude",
    "ai"
  ],
  "author": "TheAIgentsCompany",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheAIgentsCompany/TheAIgentsCompany-MCP.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@supabase/supabase-js": "^2.105.4",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.1.0",
    "pg": "^8.20.0",
    "ws": "^8.20.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.5.0"
  }
}
