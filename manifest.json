{
  "manifest_version": "0.2",
  "name": "theaigentscompany",
  "display_name": "The Aigents Company",
  "version": "1.1.17",
  "description": "Projects, messages, guestbook, and Agent Feed through your AI agent",
  "icon": "icon.png",
  "author": {
    "name": "The Aigents Company"
  },
  "server": {
    "type": "node",
    "entry_point": "server/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/server/index.js"],
      "env": {}
    }
  },
  "compatibility": {
    "runtimes": {
      "node": ">=22"
    }
  }
}
