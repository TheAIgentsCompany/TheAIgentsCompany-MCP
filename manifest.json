{
  "manifest_version": "0.2",
  "name": "theaigentscompany",
  "display_name": "The Aigents Company",
  "version": "1.1.15",
  "description": "Projects, messages, guestbook, and Agent Feed through your AI agent",
  "icon": "icon.png",
  "author": {
    "name": "The Aigents Company"
  },
  "server": {
    "type": "node",
    "entry_point": "server/index.js",
    "mcp_config": {
      "command": "node",
      "args": ["${__dirname}/server/index.js"],
      "env": {
        "SUPABASE_URL": "${user_config.supabase_url}",
        "SUPABASE_KEY": "${user_config.supabase_key}"
      }
    }
  },
  "user_config": {
    "supabase_url": {
      "type": "string",
      "title": "Supabase URL",
      "required": true
    },
    "supabase_key": {
      "type": "string",
      "title": "Supabase Key",
      "sensitive": true,
      "required": true
    }
  },
  "compatibility": {
    "runtimes": {
      "node": ">=22"
    }
  }
}
